# ── Server ────────────────────────────────────────
PORT=3001
NODE_ENV=development
FRONTEND_ORIGIN=http://localhost:5173

# ── Database (Hostinger hPanel → MySQL Databases) ─
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=navara

# ── Auth ──────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=
JWT_SECRET=
JWT_EXPIRES_IN=7d

# ── Cloudinary ────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Email (bootstrap defaults — DB overrides once seeded) ─
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=hello@navara.com
SMTP_PASS=
NOTIFY_EMAIL=omarelsady@navara.com

# ── Translations seed gate (one-shot) ─────────────
ALLOW_TRANSLATION_SEED=false

# ── Cal.com (auto-booking on contact form submit) ─
# Personal API key:  Cal.com → Settings → Developer → API keys → Create
# Event type IDs:    Cal.com → Event Types → click event → ID is in the URL (cal.com/event-types/<ID>)
# If unset, the contact form still saves the lead but does not create a Cal.com booking.
CAL_API_KEY=
CAL_EVENT_TYPE_ID_EGYPT=
CAL_EVENT_TYPE_ID_KSA=

# Send booking confirmations from OUR SMTP after a successful Cal.com booking.
# When 'true': visitor receives a confirmation from NOTIFY_EMAIL/SMTP_USER, admin is CC'd.
# To use this exclusively (no duplicate Cal.com emails): also disable email workflows
# on the event type at https://cal.com (Event Types → ⋯ → Workflows / Advanced).
EMAIL_BOOKING_CONFIRMATIONS=false
