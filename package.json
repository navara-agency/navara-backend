{
  "name": "navara-backend",
  "version": "1.0.0",
  "private": true,
  "description": "Navara Backend API — Express + Sequelize + MySQL",
  "main": "server.js",
  "scripts": {
    "dev": "nodemon server.js",
    "start": "node server.js",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "test:integration": "jest tests/integration --runInBand",
    "lint": "eslint src/ tests/",
    "migrate": "sequelize-cli db:migrate",
    "migrate:undo": "sequelize-cli db:migrate:undo",
    "seed": "node src/scripts/seed.js",
    "check:secrets": "node ../scripts/check-secrets.js"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "cloudinary": "^2.5.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "express-rate-limit": "^7.4.1",
    "jsonwebtoken": "^9.0.2",
    "lodash.merge": "^4.6.2",
    "lru-cache": "^11.0.2",
    "multer": "^1.4.5-lts.1",
    "multer-storage-cloudinary": "^4.0.0",
    "mysql2": "^3.11.5",
    "nodemailer": "^6.9.16",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "sequelize": "^6.37.5",
    "validator": "^13.12.0"
  },
  "devDependencies": {
    "eslint": "^9.16.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.7",
    "sequelize-cli": "^6.6.2",
    "sqlite3": "^5.1.7",
    "supertest": "^7.0.0"
  }
}
